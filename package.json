{
  "name": "richardkern-nz",
  "version": "1.0.0",
  "description": "Personal site and blog — richardkern.nz",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation node --env-file-if-exists=.env scripts/dev.mjs",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "tsx ./node_modules/payload/bin.js migrate:create",
    "migrate:status": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:status",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.86.0",
    "@payloadcms/db-postgres": "3.86.0",
    "@payloadcms/email-resend": "^3.86.0",
    "@payloadcms/live-preview-react": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/plugin-redirects": "3.86.0",
    "@payloadcms/plugin-seo": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/storage-s3": "3.86.0",
    "@payloadcms/ui": "3.86.0",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "17.4.2",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "next": "16.2.10",
    "next-sitemap": "^4.2.3",
    "payload": "3.86.0",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.35.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.2",
    "@types/escape-html": "^1.0.2",
    "@types/node": "22.19.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.10",
    "jsdom": "28.0.0",
    "postcss": "^8.5.18",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "tsx": "4.23.1",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": "^9 || ^10 || ^11"
  }
}
