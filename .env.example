# richardkern.nz environment variables
#
# This file doubles as the local-dev template and the block you paste straight
# into Coolify's env editor. Copy it, fill every value below, no trailing slashes.
#
# Coolify: mark ALL of these as BOTH build-time and runtime. The builder runs
# `pnpm migrate` and statically generates pages via the Payload Local API, so it
# needs the database and secrets at build. NEXT_PUBLIC_SERVER_URL in particular
# MUST be available at build: next.config bakes it into images.remotePatterns,
# and if it is missing the optimizer allowlists localhost and returns 400
# ("url" parameter is not allowed) on production media URLs.
#
# Generate fresh secrets with:  openssl rand -hex 32

# --- Core ---

# Postgres connection string.
# Local dev (docker compose): postgresql://postgres:localpassword@127.0.0.1:5432/richardkern-nz
# Coolify: use the Postgres container's INTERNAL hostname (its container name,
# port 5432) over the shared docker network, never the VPS public IP, which
# containers cannot hairpin to. The database needs no published host port.
DATABASE_URL=

# Encrypts Payload JWTs. openssl rand -hex 32
PAYLOAD_SECRET=

# Local dev server port. Single source of truth — the dev script, Playwright,
# and the media-URL fallbacks all read it. Defaults to 3000 (richardkern.nz's
# reserved port, so parallel work on a sibling project using 3001 doesn't
# clash; mirrors the per-project Postgres ports). Not used on Coolify.
PORT=3000

# Public site origin, no trailing slash. Drives CORS, canonical links, the
# sitemap and RSS, and the image optimizer's allowlist. Per environment:
# http://localhost:3000  |  https://<staging-domain>  |  https://richardkern.nz
NEXT_PUBLIC_SERVER_URL=

# Authenticates the Payload cron/jobs endpoint. openssl rand -hex 32
CRON_SECRET=

# Validates draft-preview requests from the admin. openssl rand -hex 32
PREVIEW_SECRET=

# --- Media (Cloudflare R2) ---
# When all four are set, the s3Storage plugin stores and serves media from R2;
# unset, it falls back to local disk (the dev default). From the Cloudflare R2
# dashboard. After adding/removing this plugin, regenerate and commit the admin
# importMap in the same change (see the deploy-preflight skill).
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Email (Resend) ---
# Transactional email. Optional in dev: when unset, Payload logs emails to the
# console instead of sending. Pin @payloadcms/email-resend to the exact payload
# version. From the Resend dashboard.
RESEND_API_KEY=

# --- Analytics (Umami, self-hosted) ---
# Cookieless analytics. When BOTH are set at BUILD time the tracking script
# renders; unset, no script (dev + staging default, so they stay untracked).
# NEXT_PUBLIC_* are inlined at build — mark both as build-time in Coolify.
# Production only. From the Umami dashboard (Settings > Websites > the site).
# SRC is the full tracking-script URL; WEBSITE_ID is the site's UUID.
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
